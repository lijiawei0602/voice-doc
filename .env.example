APP_NAME=voice-doc-service
APP_ENV=dev
HOST=0.0.0.0
PORT=8000
DEBUG=false

# 识别引擎: funasr 或 whisper
ENGINE=funasr
ENABLE_GPU=true
FORCE_CPU=false

MODEL_CACHE_DIR=./models
TEMP_DIR=./data/tmp
RESULT_DIR=./data/results
TASK_DIR=./data/tasks
LOG_DIR=./logs

MAX_AUDIO_DURATION_SECONDS=14400
MAX_UPLOAD_SIZE_MB=512
SAMPLE_RATE=16000
AUDIO_CHUNK_SECONDS=1800
BATCH_SIZE_SECONDS=300
DENOISE_ENABLED=true
SUPPORTED_AUDIO_EXTENSIONS=.mp3,.wav,.flac,.m4a

# FunASR
FUNASR_MODEL=paraformer-zh
FUNASR_STREAMING_MODEL=paraformer-zh-streaming
FUNASR_VAD_MODEL=fsmn-vad
FUNASR_PUNC_MODEL=ct-punc
FUNASR_SPK_MODEL=cam++
FUNASR_HUB=ms

# 模型预加载
PRELOAD_MODELS_ON_STARTUP=true

# Whisper
WHISPER_MODEL=small
WHISPER_LANGUAGE=
WHISPER_DOWNLOAD_ROOT=./models/whisper
WHISPER_COMPUTE_TYPE=float16

# pyannote
PYANNOTE_MODEL=pyannote/speaker-diarization-3.1
PYANNOTE_AUTH_TOKEN=
PYANNOTE_NUM_SPEAKERS=

TASK_WORKER_COUNT=2
